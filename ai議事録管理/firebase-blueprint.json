{
  "entities": {
    "Minute": {
      "title": "Minute",
      "description": "Meeting minutes data",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the meeting" },
        "content": { "type": "string", "description": "Original content or preview" },
        "summary": { "type": "string", "description": "AI generated summary" },
        "format": { "type": "string", "description": "Format used for generation" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "uid": { "type": "string", "description": "User ID who owns this minute" }
      },
      "required": ["title", "summary", "uid", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "Action item from a meeting",
      "type": "object",
      "properties": {
        "minuteId": { "type": "string", "description": "Reference to the minute document ID" },
        "text": { "type": "string", "description": "Task description" },
        "assignee": { "type": "string", "description": "Person assigned to the task" },
        "dueDate": { "type": "string", "format": "date", "description": "Due date for the task" },
        "status": { "type": "string", "enum": ["pending", "completed"], "description": "Current status of the task" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "uid": { "type": "string", "description": "User ID who owns this task" }
      },
      "required": ["minuteId", "text", "status", "uid", "createdAt"]
    }
  },
  "firestore": {
    "/minutes/{minuteId}": {
      "schema": "Minute",
      "description": "Collection of meeting minutes"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Collection of tasks"
    }
  }
}
